# PostgreSQL
DATABASE_URL=postgresql://hotel_intel_app:123456@localhost:5432/hotel_intel

# 9Router / OpenAI-compatible gateway
CLIPPROXYAPI_BASE_URL=http://127.0.0.1:20128/v1
CLIPPROXYAPI_API_KEY=local-9router
EXTRACTOR_MODEL=gc/gemini-3-flash-preview
VERIFIER_MODEL=gc/gemini-3-flash-preview
AI_TEMPERATURE=0
AI_RETRY_MAX=3
AI_RETRY_DELAY_MS=10000

# Collector
ZALO_SESSION_FILE=./var/zalo_session.json
COLLECTOR_INSTANCE_ID=local-zalo-collector-01

# Worker
AI_WORKER_CONCURRENCY=3
AI_WORKER_BATCH_SIZE=10
MATCH_CANDIDATE_MIN_SCORE=0.4
LLM_VERIFY_MIN_SCORE=0.4
LLM_VERIFY_MAX_SCORE=0.7
AI_VERIFY_FAIL_OPEN=false

# API
API_HOST=0.0.0.0
API_PORT=8000
JWT_SECRET=replace_me_with_long_random_value

# Dashboard
DASHBOARD_PORT=3000
PUBLIC_API_BASE_URL=http://localhost:8000
